# Copy this file to `.env` and fill in real values.
# Never commit the real `.env` file.

# OneSignal Application credentials (from OneSignal dashboard)
# Reuse the production Skillzen app so only network differs between demo and prod.
ONESIGNAL_APP_ID=6cbb5375-dae9-42c4-bbc6-21b314dc04f4
ONESIGNAL_REST_API_KEY=os_v2_app_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
ONESIGNAL_ENABLED=true

# Server
PORT=3001

# CORS allowed origin (frontend dev URL)
FRONTEND_ORIGIN=http://localhost:5173
